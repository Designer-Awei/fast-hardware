# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
#
# 打包说明：将此文件复制为仓库根目录 .env.supabase 并填写下方变量后执行 npm run dist；
# 安装版会从安装目录 resources/.env.supabase 读取（勿写入 Service Role，仅用 Publishable Key）。
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-key

# Optional: override the desktop OAuth callback URL.
# Make sure this URL is also added to Supabase Auth -> Redirect URLs.
SUPABASE_OAUTH_REDIRECT_URL=fasthardware://auth/callback
